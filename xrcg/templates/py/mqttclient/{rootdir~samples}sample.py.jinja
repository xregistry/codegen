"""
{%- filter wordwrap(80) %}
Sample usage of {{ main_project_name }}.

This example shows how to consume and publish MQTT messages with the generated
client{%- if messagegroups|length > 1 -%}s{%- endif %}. Each message group has a
`<Group>MqttClient` that wraps a paho-mqtt client and both dispatches received
messages to async handlers you register and exposes `publish_<message>`
coroutines to send messages.

Message handlers are async functions. CloudEvents message handlers receive
`(mqtt_message, cloud_event, data, topic_params)`; plain (non-CloudEvents)
message handlers receive `(mqtt_message, data, topic_params)` where:
  - mqtt_message: the paho.mqtt.client.MQTTMessage (raw message context),
  - cloud_event: the CloudEvent envelope (CloudEvents messages only),
  - data: the deserialized, strongly-typed message data,
  - topic_params: dict of URI-template placeholders extracted from the topic.

Configuration is read from the command line or these environment variables:
  - MQTT_BROKER_HOST: broker hostname (default: localhost),
  - MQTT_BROKER_PORT: broker port (default: 1883),
  - MQTT_USERNAME: username (optional),
  - MQTT_PASSWORD: password (optional).

    python sample.py --broker-host <host> --broker-port <port>

The sample connects, subscribes, publishes one example of each message, then
waits for incoming messages until interrupted (press Ctrl+C to stop).
{%- endfilter %}
"""

import argparse
import asyncio
import os
import signal

import paho.mqtt.client as mqtt

from {{ data_project_name }} import *
{%- for messagegroupid, messagegroup in messagegroups.items() %}
{%- set class_name = (messagegroupid | pascal | strip_dots) + "MqttClient" %}
from {{ main_project_name }}.client import {{ class_name }}
{%- endfor %}

{% for messagegroupid, messagegroup in messagegroups.items() %}
{%- for messageid, message in messagegroup.messages.items() %}
{%- set handler_attr = messageid | dotunderscore | snake %}
{%- set isCloudEvent = (message | exists("envelope","CloudEvents/1.0")) %}
{%- if isCloudEvent %}
async def handle_{{ handler_attr }}(mqtt_message, cloud_event, data, topic_params):
    """Handle the CloudEvents '{{ messageid }}' message."""
    print(f"Received {{ messageid }} on topic {mqtt_message.topic}")
    print(f"  CloudEvent: id={cloud_event['id']} source={cloud_event['source']} type={cloud_event['type']}")
    print(f"  Data: {data}")
    if topic_params:
        print(f"  Topic params: {topic_params}")
{%- else %}
async def handle_{{ handler_attr }}(mqtt_message, data, topic_params):
    """Handle the plain (non-CloudEvents) '{{ messageid }}' message."""
    print(f"Received {{ messageid }} on topic {mqtt_message.topic}")
    print(f"  Data: {data}")
    if topic_params:
        print(f"  Topic params: {topic_params}")
{%- endif %}

{% endfor %}
{%- endfor %}

def _make_paho_client(client_id):
    """Create a paho-mqtt client compatible with paho-mqtt 1.x and 2.x.

    The generated client callbacks use the VERSION1 callback signatures, so we
    request that API version when running on paho-mqtt 2.x.
    """
    try:
        return mqtt.Client(mqtt.CallbackAPIVersion.VERSION1, client_id=client_id)
    except (AttributeError, TypeError):
        return mqtt.Client(client_id=client_id)


async def publish_samples(clients):
    """Publish one example of each message type using generated test data."""
    {%- for messagegroupid, messagegroup in messagegroups.items() %}
    client = clients["{{ messagegroupid }}"]
    {%- for messageid, message in messagegroup.messages.items() %}
    {%- set isCloudEvent = (message | exists("envelope","CloudEvents/1.0")) %}
    {%- set pub_method = "publish_" + (messageid | dotunderscore | snake) %}
    {%- set data_class = util.DeclareDataType( data_project_name, root, message ) | strip_namespace %}
    {%- set uri_template_vars = [] %}
    {%- if isCloudEvent %}
    {%- for attrname, attribute in message.envelopemetadata.items() %}
        {%- if attribute.value and attribute.type == "uritemplate" and attrname != "time" %}
            {%- for placeholder in (attribute.value | regex_search('\\{([A-Za-z0-9_]+)\\}')) %}
                {%- if placeholder not in uri_template_vars %}{%- set _ = uri_template_vars.append(placeholder) %}{%- endif %}
            {%- endfor %}
        {%- endif %}
    {%- endfor %}
    {%- endif %}
    {%- set _topic_value = none %}
    {%- if message.protocoloptions and message.protocoloptions.topic_name %}{%- set _topic_value = message.protocoloptions.topic_name %}
    {%- elif message.protocoloptions and message.protocoloptions['topic-name'] %}{%- set _topic_value = message.protocoloptions['topic-name'] %}
    {%- elif message.protocoloptions and message.protocoloptions.topic %}{%- set _topic_value = message.protocoloptions.topic %}{%- endif %}
    {%- if _topic_value %}
    {%- for placeholder in (_topic_value | regex_search('\\{([A-Za-z0-9_]+)\\}')) %}
        {%- if placeholder not in uri_template_vars %}{%- set _ = uri_template_vars.append(placeholder) %}{%- endif %}
    {%- endfor %}
    {%- endif %}
    {%- if data_class != "object" %}
    try:
        await client.{{ pub_method }}(
            {%- if isCloudEvent %}
            {%- for attrname, attribute in message.envelopemetadata.items() if not attribute.value %}
            {%- if attribute.type != "uritemplate" and attrname != "time" %}
            _{{ attrname | snake }}="sample",
            {%- endif %}
            {%- endfor %}
            {%- endif %}
            {%- for var in uri_template_vars %}
            {{ var | snake }}="sample",
            {%- endfor %}
            data={{ data_class }}.create_instance(),
        )
        print("Published {{ messageid }}")
    except Exception as exc:
        print(f"Could not publish {{ messageid }}: {exc}")
    {%- else %}
    # '{{ messageid }}' has no typed schema (object payload);
    # build your own payload and call client.{{ pub_method }}(..., data=<payload>).
    {%- endif %}
    {%- endfor %}
    {%- endfor %}


async def main(broker_host, broker_port, username=None, password=None):
    """Set up the client(s), connect, subscribe, publish samples, then listen."""
    loop = asyncio.get_running_loop()
    clients = {}

    {% for messagegroupid, messagegroup in messagegroups.items() %}
    {%- set class_name = (messagegroupid | pascal | strip_dots) + "MqttClient" %}
    {%- set groupName = messagegroupid.split('.') | join('_') | lower %}
    _paho = _make_paho_client("sample-{{ groupName }}")
    if username:
        _paho.username_pw_set(username, password)
    _client = {{ class_name }}(_paho, content_mode='structured', loop=loop)
    {%- for messageid, message in messagegroup.messages.items() %}
    _client.{{ messageid | dotunderscore | snake }}_async = handle_{{ messageid | dotunderscore | snake }}
    {%- endfor %}
    clients["{{ messagegroupid }}"] = _client
    {% endfor %}

    print(f"Connecting to {broker_host}:{broker_port} ...")
    for client in clients.values():
        await client.connect(broker_host, broker_port)
        await client.subscribe()
    print("Connected and subscribed.")

    # Give subscriptions a moment to take effect, then publish a sample of each message.
    await asyncio.sleep(1)
    await publish_samples(clients)

    stop_event = asyncio.Event()
    try:
        loop.add_signal_handler(signal.SIGINT, stop_event.set)
        loop.add_signal_handler(signal.SIGTERM, stop_event.set)
    except NotImplementedError:
        # Signal handlers are not available on this platform (e.g. Windows).
        pass

    print("Listening for messages. Press Ctrl+C to stop.")
    try:
        await stop_event.wait()
    except (KeyboardInterrupt, asyncio.CancelledError):
        pass

    print("\nStopping...")
    for client in clients.values():
        await client.disconnect()


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="MQTT Client sample")
    parser.add_argument('--broker-host', default=os.getenv('MQTT_BROKER_HOST', 'localhost'), help='MQTT broker hostname')
    parser.add_argument('--broker-port', type=int, default=int(os.getenv('MQTT_BROKER_PORT', '1883')), help='MQTT broker port')
    parser.add_argument('--username', default=os.getenv('MQTT_USERNAME'), help='MQTT username (optional)')
    parser.add_argument('--password', default=os.getenv('MQTT_PASSWORD'), help='MQTT password (optional)')

    args = parser.parse_args()

    try:
        asyncio.run(main(
            args.broker_host,
            args.broker_port,
            args.username,
            args.password
        ))
    except KeyboardInterrupt:
        print("\nStopped.")
