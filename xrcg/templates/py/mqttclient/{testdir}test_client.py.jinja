@pytest.mark.asyncio
async def test_{{groupName}}_{{messagename.split('.')[-1]}}_plain_py(mosquitto_broker):
    """Test receiving a plain (non-CloudEvents) {{ messageid }} message via MQTT.

    The publisher is a raw paho client that emits plain JSON on the wire
    (simulating a third-party, non-CloudEvents broker feed). The generated
    client must dispatch it to the registered handler with the deserialized
    data object and the topic-template parameters extracted from the topic.
    """
    import re as _re
    from {{main_project_name}}.client import get_default_topic_mappings_{{ groupName }}
    broker_host, broker_port = mosquitto_broker

    {%- if type_name != "object" %}
    # Create valid test data using the test helper
    test_data = Test_{{ type_name | pascal | strip_namespace }}.create_instance()
    payload = test_data.to_byte_array("application/json")
    if isinstance(payload, str):
        payload = payload.encode("utf-8")
    {%- else %}
    payload = b"{}"
    {%- endif %}

    # Build a concrete topic from the message's URI-template topic
    _topic_template = get_default_topic_mappings_{{ groupName }}()["{{ messageid }}"]
    _placeholders = _re.findall(r'\{([A-Za-z0-9_]+)\}', _topic_template)
    expected_params = {ph: f"val{idx}" for idx, ph in enumerate(_placeholders)}
    concrete_topic = _topic_template
    for _ph, _val in expected_params.items():
        concrete_topic = concrete_topic.replace("{" + _ph + "}", _val)

    # Subscriber uses the generated client
    subscriber_mqtt = mqtt.Client(client_id="test_plain_subscriber")
    loop = asyncio.get_running_loop()
    subscriber_client = {{ class_name }}(subscriber_mqtt, content_mode='structured', loop=loop)

    # Publisher is a raw paho client emitting plain JSON (no CloudEvents envelope)
    publisher_mqtt = mqtt.Client(client_id="test_plain_publisher")

    received_data = []
    received_params = []
    received_event = asyncio.Event()

    async def on_{{messagename.split('.')[-1]}}(mqtt_msg, data{% if type_name != "object" %}: {{type_name}}{% endif %}, topic_params: dict):
        """Handler for plain {{ messageid }} messages."""
        received_data.append(data)
        received_params.append(topic_params)
        if len(received_data) >= 5:
            received_event.set()

    # Register handler
    subscriber_client.{{messagename.split('.')[-1]}}_async = on_{{messagename.split('.')[-1]}}

    # Connect both clients
    await subscriber_client.connect(broker_host, broker_port)
    publisher_mqtt.connect(broker_host, int(broker_port))
    publisher_mqtt.loop_start()

    # Subscribe to the concrete topic
    await subscriber_client.subscribe([concrete_topic])

    # Wait for subscription to be active
    await asyncio.sleep(1)

    # Publish 5 plain-JSON messages
    for _ in range(5):
        publisher_mqtt.publish(concrete_topic, payload, qos=1)

    # Wait for all 5 messages to be received (with timeout)
    try:
        await asyncio.wait_for(received_event.wait(), timeout=10.0)
    except asyncio.TimeoutError:
        pytest.fail(f"Did not receive all 5 plain messages within timeout, got {len(received_data)}")

    # Verify all 5 messages received
    assert len(received_data) == 5, f"Expected 5 messages, got {len(received_data)}"

    # Verify topic-template parameters were extracted and handed to the handler
    if _placeholders:
        assert received_params[0] == expected_params, f"Expected {expected_params}, got {received_params[0]}"

    # Cleanup
    publisher_mqtt.loop_stop()
    publisher_mqtt.disconnect()
    await subscriber_client.disconnect()


