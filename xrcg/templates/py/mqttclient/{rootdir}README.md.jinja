async def main():
    # paho-mqtt 2.x requires a callback API version; the generated client uses
    # the VERSION1 callback signatures.
    paho_client = mqtt.Client(mqtt.CallbackAPIVersion.VERSION1, client_id="example")

    # 'structured' or 'binary' controls CloudEvents serialization on publish.
    client = {{ class_name }}(paho_client, content_mode='structured')
{% for messageid, message in messagegroup.messages.items() -%}
{%- if loop.first -%}
{%- set isCloudEvent = (message | exists("envelope","CloudEvents/1.0")) -%}
{%- set handler_attr = messageid | dotunderscore | snake %}
    # Register an async handler for received '{{ messageid }}' messages.
{%- if isCloudEvent %}
    async def on_{{ handler_attr }}(mqtt_message, cloud_event, data, topic_params):
        print(f"{cloud_event['type']} {data} {topic_params}")
{%- else %}
    async def on_{{ handler_attr }}(mqtt_message, data, topic_params):
        print(f"{data} {topic_params}")
{%- endif %}
    client.{{ handler_attr }}_async = on_{{ handler_attr }}
{%- endif -%}
{%- endfor %}

    await client.connect("localhost", 1883)
    await client.subscribe()            # subscribe to all message topics

    # ... publish / receive messages ...

    await client.disconnect()


asyncio.run(main())
