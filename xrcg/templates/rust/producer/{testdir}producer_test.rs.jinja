/// Verifies a structured-mode send reaches the endpoint as `cloudevents+json`.
#[test]
fn {{ struct_name | snake }}_{{ messagename | snake }}_structured() {
    let (url, handle) = serve_once();
    let producer = {{ struct_name }}::new(url).expect("create producer");
    producer
        .send_{{ messagename | snake }}({{ send_args }})
        .expect("send {{ messagename }}");
    let captured = handle.join().expect("join server");
    assert!(captured.body_len > 0, "endpoint should have received a body");
    assert!(
        captured.content_type.contains("cloudevents+json"),
        "structured mode should use the cloudevents+json media type, got: {}",
        captured.content_type
    );
}

