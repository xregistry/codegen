const liveEhConfig = `{
  "UserConfig": {
    "NamespaceConfig": [
      {
        "Type": "EventHub",
        "Name": "emulatorNs1",
        "Entities": [
          {
            "Name": "eh1",
            "PartitionCount": "1",
            "ConsumerGroups": [
              { "Name": "cg1" }
            ]
          }
        ]
      }
    ],
    "LoggingConfig": { "Type": "File" }
  }
}`

// Test{{ live_group_class }}_LiveRoundTrip starts an Event Hubs emulator, produces
// the first message with the generated producer, and verifies it round-trips
// through the broker by reading it with the raw azeventhubs SDK. Skips when Docker
// is unavailable.
func Test{{ live_group_class }}_LiveRoundTrip(t *testing.T) {
	testcontainers.SkipIfProviderIsNotHealthy(t)

	ctx := context.Background()
	container, err := eventhubs.Run(ctx,
		"mcr.microsoft.com/azure-messaging/eventhubs-emulator:2.1.0",
		eventhubs.WithAcceptEULA(),
		eventhubs.WithConfig(strings.NewReader(liveEhConfig)),
	)
	require.NoError(t, err)
	defer func() { _ = testcontainers.TerminateContainer(container) }()

	connStr, err := container.ConnectionString(ctx)
	require.NoError(t, err)

	producer, err := New{{ live_group_class }}(connStr, "eh1")
	require.NoError(t, err)
	defer producer.Close(ctx)

	var testData {{ live_body_type }}
	var sendErr error
	for i := 0; i < 5; i++ {
		if sendErr = producer.Send{{ live_messagename }}(ctx, testData{% if live_needs_source %}, "tenant123/device456"{% endif %}{% if "type" not in live_first_message.envelopemetadata %}, "{{ live_first_message_id }}"{% endif %}); sendErr == nil {
			break
		}
		time.Sleep(2 * time.Second)
	}
	require.NoError(t, sendErr)

	consumerClient, err := azeventhubs.NewConsumerClientFromConnectionString(connStr, "eh1", azeventhubs.DefaultConsumerGroup, nil)
	require.NoError(t, err)
	defer consumerClient.Close(ctx)
	partClient, err := consumerClient.NewPartitionClient("0", &azeventhubs.PartitionClientOptions{
		StartPosition: azeventhubs.StartPosition{Earliest: to.Ptr(true)},
	})
	require.NoError(t, err)
	defer partClient.Close(ctx)

	rctx, cancel := context.WithTimeout(ctx, 30*time.Second)
	defer cancel()
	events, err := partClient.ReceiveEvents(rctx, 1, nil)
	require.NoError(t, err)
	require.Len(t, events, 1)
	require.NotNil(t, events[0].ContentType)
	assert.Equal(t, "application/cloudevents+json", *events[0].ContentType)

	var envelope map[string]any
	require.NoError(t, json.Unmarshal(events[0].Body, &envelope))
	assert.Equal(t, "{{ live_event_type }}", envelope["type"])
}
