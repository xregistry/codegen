// ContentMode specifies how a CloudEvent is bound to the HTTP request.
type ContentMode string

const (
	// ContentModeStructured sends the whole CloudEvent as application/cloudevents+json.
	ContentModeStructured ContentMode = "structured"
	// ContentModeBinary sends the event data as the body and the CloudEvents
	// attributes as ce-* HTTP headers (CloudEvents HTTP binary content mode).
	ContentModeBinary ContentMode = "binary"
)

