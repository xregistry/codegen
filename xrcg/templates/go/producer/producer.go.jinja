// New{{ class_name }} creates a {{ class_name }} that posts to target using structured content mode (default).
func New{{ class_name }}(target string) (*{{ class_name }}, error) {
	client, err := cloudevents.NewClientHTTP()
	if err != nil {
		return nil, fmt.Errorf("failed to create CloudEvents HTTP client: %w", err)
	}
	return &{{ class_name }}{
		client:      client,
		target:      target,
		contentMode: ContentModeStructured,
	}, nil
}

// New{{ class_name }}WithClient creates a {{ class_name }} with an existing CloudEvents client (useful for testing).
func New{{ class_name }}WithClient(client cloudevents.Client, target string) *{{ class_name }} {
	return &{{ class_name }}{
		client:      client,
		target:      target,
		contentMode: ContentModeStructured,
	}
}

// SetContentMode sets the HTTP content mode used for subsequent sends.
func (p *{{ class_name }}) SetContentMode(mode ContentMode) {
	p.contentMode = mode
}

// Close releases any resources held by the producer.
func (p *{{ class_name }}) Close() error {
	return nil
}

// send binds the event using the configured content mode and posts it to the target.
func (p *{{ class_name }}) send(ctx context.Context, event cloudevents.Event) error {
	sendCtx := cloudevents.ContextWithTarget(ctx, p.target)
	if p.contentMode == ContentModeBinary {
		sendCtx = binding.WithForceBinary(sendCtx)
	} else {
		sendCtx = binding.WithForceStructured(sendCtx)
	}
	if result := p.client.Send(sendCtx, event); cloudevents.IsUndelivered(result) {
		return fmt.Errorf("failed to deliver event: %w", result)
	}
	return nil
}

