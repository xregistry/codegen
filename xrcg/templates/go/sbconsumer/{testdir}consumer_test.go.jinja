func Test{{ class_name }}_CanUseFakeReceiver(t *testing.T) {
	handler := &mock{{ class_name }}Handler{}
	receiver := &fakeServiceBusReceiver{}
	consumer := New{{ class_name }}WithReceiver(receiver, handler)

	assert.NotNil(t, consumer)
	assert.NoError(t, consumer.Close(context.Background()))
}

