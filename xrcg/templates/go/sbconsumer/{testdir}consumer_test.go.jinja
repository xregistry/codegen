// Test{{ live_group_class }}_LiveRoundTrip starts a Service Bus emulator, sends a
// structured CloudEvent with the raw azservicebus SDK, and verifies the generated
// consumer dispatches it to the handler. Skips when Docker is unavailable.
func Test{{ live_group_class }}_LiveRoundTrip(t *testing.T) {
	testcontainers.SkipIfProviderIsNotHealthy(t)

	ctx := context.Background()
	container, err := servicebus.Run(ctx,
		"mcr.microsoft.com/azure-messaging/servicebus-emulator:1.1.2",
		servicebus.WithAcceptEULA(),
		servicebus.WithConfig(strings.NewReader(liveSbConsumerConfig)),
	)
	require.NoError(t, err)
	defer func() { _ = testcontainers.TerminateContainer(container) }()

	connStr, err := container.ConnectionString(ctx)
	require.NoError(t, err)

	var data {{ live_body_type }}
	event := cloudevents.NewEvent()
	event.SetSpecVersion("1.0")
	event.SetID("live-1")
	event.SetType("{{ live_event_type }}")
	event.SetSource("test/source")
	event.SetTime(time.Now())
	require.NoError(t, event.SetData("application/json", data))
	body, err := json.Marshal(event)
	require.NoError(t, err)
	contentType := "application/cloudevents+json"

	client, err := azservicebus.NewClientFromConnectionString(connStr, nil)
	require.NoError(t, err)
	defer client.Close(ctx)
	sender, err := client.NewSender("queue.1", nil)
	require.NoError(t, err)
	defer sender.Close(ctx)

	msg := &azservicebus.Message{Body: body, ContentType: &contentType}
	var sendErr error
	for i := 0; i < 5; i++ {
		if sendErr = sender.SendMessage(ctx, msg, nil); sendErr == nil {
			break
		}
		time.Sleep(2 * time.Second)
	}
	require.NoError(t, sendErr)

	handler := &live{{ live_group_class }}Handler{received: make(chan string, 1)}
	consumer, err := New{{ live_group_class }}(connStr, "queue.1", handler)
	require.NoError(t, err)
	defer consumer.Close(ctx)
	go func() { _ = consumer.Start(ctx) }()

	select {
	case typ := <-handler.received:
		require.Equal(t, "{{ live_event_type }}", typ)
	case <-time.After(60 * time.Second):
		consumer.Stop()
		t.Fatal("timed out waiting for consumer to dispatch message")
	}
	consumer.Stop()
}
