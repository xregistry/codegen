type fakeServiceBusReceiver struct {
	messages []*azservicebus.ReceivedMessage
	complete int
}

func (r *fakeServiceBusReceiver) ReceiveMessages(ctx context.Context, maxMessages int, options *azservicebus.ReceiveMessagesOptions) ([]*azservicebus.ReceivedMessage, error) {
	messages := r.messages
	r.messages = nil
	return messages, nil
}

func (r *fakeServiceBusReceiver) CompleteMessage(ctx context.Context, message *azservicebus.ReceivedMessage, options *azservicebus.CompleteMessageOptions) error {
	r.complete++
	return nil
}

func (r *fakeServiceBusReceiver) Close(ctx context.Context) error { return nil }

