func cloudEventFromBinaryPublish(pub *paho.Publish) (cloudevents.Event, error) {
	event := cloudevents.NewEvent()
	if pub.Properties != nil {
		for _, user := range pub.Properties.User {
			switch strings.ToLower(user.Key) {
			case "specversion":
				event.SetSpecVersion(user.Value)
			case "type":
				event.SetType(user.Value)
			case "source":
				event.SetSource(user.Value)
			case "subject":
				event.SetSubject(user.Value)
			case "id":
				event.SetID(user.Value)
			case "time":
				if t, err := time.Parse(time.RFC3339Nano, user.Value); err == nil {
					event.SetTime(t)
				}
			default:
				event.SetExtension(strings.ToLower(user.Key), user.Value)
			}
		}
		if pub.Properties.ContentType != "" {
			event.SetDataContentType(pub.Properties.ContentType)
		}
	}
	if err := event.SetData(event.DataContentType(), pub.Payload); err != nil {
		return event, err
	}
	return event, nil
}

