func topicToWildcard(topic string) string {
	return regexp.MustCompile(`\{[A-Za-z0-9_]+\}`).ReplaceAllString(topic, "+")
}

func buildTopicRegex(topic string) *regexp.Regexp {
	escaped := regexp.QuoteMeta(topic)
	re := regexp.MustCompile(`\\\{([A-Za-z0-9_]+)\\\}`).ReplaceAllString(escaped, `(?P<$1>[^/]+)`)
	return regexp.MustCompile("^" + re + "$")
}

func extractTopicParams(topic string, pattern *regexp.Regexp) map[string]string {
