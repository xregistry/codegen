	err := client.Publish{{ messagename }}(context.Background(), data{% for var in topic_vars %}, "test-{{ var }}"{% endfor %}{% for var in source_vars %}, "test-{{ var }}"{% endfor %}{% if needs_source_param %}, "test-source"{% endif %}{% if needs_type_param %}, "{{ messageid }}"{% endif %}{% for attr in extension_params %}, "test-{{ attr }}"{% endfor %})
