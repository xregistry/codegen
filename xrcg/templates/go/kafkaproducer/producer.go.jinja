// writeWithRetry sends a message with retry and exponential backoff.
func (p *{{ class_name }}) writeWithRetry(ctx context.Context, msg kafka.Message, retries int, backoffFactor float64) error {
	var lastErr error
	for attempt := 1; attempt <= retries; attempt++ {
		lastErr = p.writer.WriteMessages(ctx, msg)
		if lastErr == nil {
			return nil
		}
		if attempt < retries {
			backoff := time.Duration(math.Pow(backoffFactor, float64(attempt)) * float64(time.Second))
			select {
			case <-ctx.Done():
				return ctx.Err()
			case <-time.After(backoff):
			}
		}
	}
	return lastErr
}

