// flushTestWriter is a fake KafkaMessageWriter used to exercise the resilient
// delivery path and Flush without a live broker. It fails the first
// failuresBeforeSuccess WriteMessages calls (or every call when alwaysFail is
// set), then succeeds, counting every attempt.
type flushTestWriter struct {
	calls                 int
	failuresBeforeSuccess int
	alwaysFail            bool
}

func (w *flushTestWriter) WriteMessages(ctx context.Context, msgs ...kafka.Message) error {
	w.calls++
	if w.alwaysFail || w.calls <= w.failuresBeforeSuccess {
		return fmt.Errorf("transient broker error (call %d)", w.calls)
	}
	return nil
}

func (w *flushTestWriter) Close() error { return nil }

// Test{{ fg_class_name }}_FlushIsNoOp verifies that Flush returns without error
// when the context is live (the synchronous writer has nothing to drain) and
// that it honors context cancellation.
func Test{{ fg_class_name }}_FlushIsNoOp(t *testing.T) {
	producer := New{{ fg_class_name }}WithWriter(&flushTestWriter{}, "{{ fg_topic }}")

	require.NoError(t, producer.Flush(context.Background(), 3, 2.0))

	cancelledCtx, cancel := context.WithCancel(context.Background())
	cancel()
	assert.ErrorIs(t, producer.Flush(cancelledCtx, 3, 2.0), context.Canceled)
}

// Test{{ fg_class_name }}_SendRetriesThenSucceeds verifies that a transient
// write failure is retried by the resilient send path and eventually succeeds.
func Test{{ fg_class_name }}_SendRetriesThenSucceeds(t *testing.T) {
	writer := &flushTestWriter{failuresBeforeSuccess: 2}
	producer := New{{ fg_class_name }}WithWriter(writer, "{{ fg_topic }}")

	var testData {{ fg_body_type }}

	ctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)
	defer cancel()

	err := {% if fg_isCloudEvent %}producer.Send{{ fg_messagename }}(ctx, testData{% if fg_needs_source_param %}, "tenant123/device456"{% endif %}{% if "type" not in first_message.envelopemetadata %}, "{{ first_message_id }}"{% endif %}){% else %}producer.Send{{ fg_messagename }}(ctx, testData, "{{ fg_topic }}"){% endif %}
	require.NoError(t, err)
	assert.Equal(t, 3, writer.calls, "expected two retries before the successful write")
}

// Test{{ fg_class_name }}_SendReturnsErrorAfterRetriesExhausted verifies that the
// resilient send path gives up after exhausting its retries and returns the error.
func Test{{ fg_class_name }}_SendReturnsErrorAfterRetriesExhausted(t *testing.T) {
	writer := &flushTestWriter{alwaysFail: true}
	producer := New{{ fg_class_name }}WithWriter(writer, "{{ fg_topic }}")

	var testData {{ fg_body_type }}

