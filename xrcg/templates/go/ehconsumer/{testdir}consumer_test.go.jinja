type fakeEventReceiver struct {
	events []*azeventhubs.ReceivedEventData
	called bool
}

func (r *fakeEventReceiver) ReceiveEvents(ctx context.Context, count int) ([]*azeventhubs.ReceivedEventData, error) {
	if r.called {
		return nil, context.Canceled
	}
	r.called = true
	return r.events, nil
}

