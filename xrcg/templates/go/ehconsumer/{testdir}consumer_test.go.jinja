func Test{{ class_name }}_DispatchesStructuredEvent(t *testing.T) {
	var testData {{ message_body_type }}
	_ = {{ data_project_name | snake }}.Opt(0)
	{%- if isCloudEvent %}
	event := cloudevents.NewEvent()
	event.SetSpecVersion("1.0")
	event.SetID("test-id")
	event.SetType("{{ event_type }}")
	event.SetSource("test/source")
	event.SetTime(time.Now())
	event.SetDataContentType("application/json")
	require.NoError(t, event.SetData("application/json", testData))
	body, err := json.Marshal(event)
	require.NoError(t, err)
	contentType := "application/cloudevents+json"
	received := &azeventhubs.ReceivedEventData{EventData: azeventhubs.EventData{Body: body, ContentType: &contentType, Properties: map[string]any{}}}
	{%- else %}
	body, err := json.Marshal(testData)
	require.NoError(t, err)
	contentType := "application/json"
	received := &azeventhubs.ReceivedEventData{EventData: azeventhubs.EventData{Body: body, ContentType: &contentType, Properties: map[string]any{"xregistry:messageid": "{{ first_message_id }}}"}}
	{%- endif %}

	handler := NewMock{{ class_name }}Handler()
	consumer := New{{ class_name }}WithReceiver(&fakeEventReceiver{events: []*azeventhubs.ReceivedEventData{received}}, handler)
	require.NoError(t, consumer.Start(context.Background()))

	handler.mu.Lock()
	defer handler.mu.Unlock()
	assert.Equal(t, 1, handler.messages["{{ first_message_id }}"])
	assert.Empty(t, handler.errors)
}

func Test{{ class_name }}_DispatchesBinaryEvent(t *testing.T) {
	var testData {{ message_body_type }}
	_ = {{ data_project_name | snake }}.Opt(0)
	{%- if message_body_type == "[]byte" %}
	body := testData
	{%- else %}
	body, err := json.Marshal(testData)
	require.NoError(t, err)
	{%- endif %}
	contentType := "application/json"
	properties := map[string]any{}
	{%- if isCloudEvent %}
	properties["cloudEvents:specversion"] = "1.0"
	properties["cloudEvents:id"] = "test-id"
	properties["cloudEvents:type"] = "{{ event_type }}"
	properties["cloudEvents:source"] = "test/source"
	properties["cloudEvents:time"] = time.Now().Format(time.RFC3339)
	properties["cloudEvents:datacontenttype"] = "application/json"
	{%- else %}
	properties["xregistry:messageid"] = "{{ first_message_id }}"
	{%- endif %}
	received := &azeventhubs.ReceivedEventData{EventData: azeventhubs.EventData{Body: body, ContentType: &contentType, Properties: properties}}

	handler := NewMock{{ class_name }}Handler()
	consumer := New{{ class_name }}WithReceiver(&fakeEventReceiver{events: []*azeventhubs.ReceivedEventData{received}}, handler)
	require.NoError(t, consumer.Start(context.Background()))

	handler.mu.Lock()
	defer handler.mu.Unlock()
	assert.Equal(t, 1, handler.messages["{{ first_message_id }}"], fmt.Sprintf("handler messages: %#v", handler.messages))
	assert.Empty(t, handler.errors)
}

