func (h *Mock{{ class_name }}Handler) Handle{{ messagename }}(ctx context.Context, {% if isCloudEvent %}event cloudevents.Event, {% endif %}data {{ message_body_type }}) error {
	h.mu.Lock()
	defer h.mu.Unlock()
	h.messages["{{ messageid }}"]++
	return nil
}

