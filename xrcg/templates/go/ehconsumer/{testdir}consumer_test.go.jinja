// Test{{ live_group_class }}_LiveRoundTrip starts an Event Hubs emulator, repeatedly
// publishes a structured CloudEvent with the raw azeventhubs SDK (so at least one
// event lands after the partition read position is established), and verifies the
// generated consumer dispatches it to the handler. Skips when Docker is unavailable.
func Test{{ live_group_class }}_LiveRoundTrip(t *testing.T) {
	testcontainers.SkipIfProviderIsNotHealthy(t)

	ctx := context.Background()
	container, err := eventhubs.Run(ctx,
		"mcr.microsoft.com/azure-messaging/eventhubs-emulator:2.1.0",
		eventhubs.WithAcceptEULA(),
		eventhubs.WithConfig(strings.NewReader(liveEhConsumerConfig)),
	)
	require.NoError(t, err)
	defer func() { _ = testcontainers.TerminateContainer(container) }()

	connStr, err := container.ConnectionString(ctx)
	require.NoError(t, err)

	var data {{ live_body_type }}
	event := cloudevents.NewEvent()
	event.SetSpecVersion("1.0")
	event.SetID("live-1")
	event.SetType("{{ live_event_type }}")
	event.SetSource("test/source")
	event.SetTime(time.Now())
	require.NoError(t, event.SetData("application/json", data))
	body, err := json.Marshal(event)
	require.NoError(t, err)
	contentType := "application/cloudevents+json"

	producerClient, err := azeventhubs.NewProducerClientFromConnectionString(connStr, "eh1", nil)
	require.NoError(t, err)
	defer producerClient.Close(ctx)

	handler := &live{{ live_group_class }}Handler{received: make(chan string, 1)}
	consumer, err := New{{ live_group_class }}(connStr, "eh1", "0", handler)
	require.NoError(t, err)
	defer consumer.Close(ctx)

	consumerCtx, cancelConsumer := context.WithCancel(ctx)
	go func() { _ = consumer.Start(consumerCtx) }()

	// Publish repeatedly so at least one event lands after the partition client's
	// read position (Latest) is established.
	stopProducing := make(chan struct{})
	go func() {
		ticker := time.NewTicker(1 * time.Second)
		defer ticker.Stop()
		for {
			select {
			case <-stopProducing:
				return
			default:
			}
			batch, berr := producerClient.NewEventDataBatch(ctx, nil)
			if berr == nil {
				if aerr := batch.AddEventData(&azeventhubs.EventData{Body: body, ContentType: &contentType}, nil); aerr == nil {
					_ = producerClient.SendEventDataBatch(ctx, batch, nil)
				}
			}
			select {
			case <-stopProducing:
				return
			case <-ticker.C:
			}
		}
	}()

	select {
	case typ := <-handler.received:
		require.Equal(t, "{{ live_event_type }}", typ)
	case <-time.After(90 * time.Second):
		close(stopProducing)
		cancelConsumer()
		t.Fatal("timed out waiting for consumer to dispatch event")
	}
	close(stopProducing)
	cancelConsumer()
	consumer.Stop()
}
