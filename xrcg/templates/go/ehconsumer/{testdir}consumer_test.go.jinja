// Mock{{ class_name }}Handler records handled messages for unit tests.
type Mock{{ class_name }}Handler struct {
	mu       sync.Mutex
	messages map[string]int
	errors   []error
}

func NewMock{{ class_name }}Handler() *Mock{{ class_name }}Handler {
	return &Mock{{ class_name }}Handler{messages: map[string]int{}}
}

