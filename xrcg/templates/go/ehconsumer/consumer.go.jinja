func eventDataContentType(eventData *azeventhubs.ReceivedEventData) string {
	if eventData.ContentType == nil {
		return ""
	}
	return *eventData.ContentType
}

func getEventHubPropertyString(eventData *azeventhubs.ReceivedEventData, key string) string {
	value, ok := eventData.Properties[key]
	if !ok || value == nil {
		return ""
	}
	switch v := value.(type) {
	case string:
		return v
	case []byte:
		return string(v)
	default:
		return fmt.Sprint(v)
	}
}

func isCoreCloudEventAttribute(name string) bool {
	switch name {
	case "specversion", "id", "type", "source", "subject", "time", "datacontenttype":
		return true
	default:
		return false
	}
}