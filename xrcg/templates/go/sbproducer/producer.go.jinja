			if err != nil {
				return nil, fmt.Errorf("failed to serialize data: %w", err)
			}
		default:
			var err error
			payload, err = json.Marshal(data)
			if err != nil {
				return nil, fmt.Errorf("failed to marshal data: %w", err)
			}
		}
		props := map[string]any{
			"cloudEvents:specversion":     event.SpecVersion(),
			"cloudEvents:id":              event.ID(),
			"cloudEvents:type":            event.Type(),
			"cloudEvents:source":          event.Source(),
			"cloudEvents:time":            event.Time().Format(time.RFC3339),
			"cloudEvents:datacontenttype": contentType,
		}
		if event.Subject() != "" {
			props["cloudEvents:subject"] = event.Subject()
		}
		for name, val := range event.Extensions() {
			props["cloudEvents:"+name] = fmt.Sprint(val)
		}
		return &azservicebus.Message{Body: payload, ContentType: &contentType, ApplicationProperties: props}, nil
	}

	contentType := "application/cloudevents+json"
	payload, err := json.Marshal(event)
	if err != nil {
		return nil, fmt.Errorf("failed to marshal CloudEvent: %w", err)
	}
	return &azservicebus.Message{Body: payload, ContentType: &contentType}, nil
}

