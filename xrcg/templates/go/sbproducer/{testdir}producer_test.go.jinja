// Test{{ fg_class_name }}_LiveRoundTrip starts a Service Bus emulator, produces the
// first message with the generated producer, and verifies it round-trips through
// the broker by receiving it with the raw azservicebus SDK. Skips when Docker is
// unavailable.
func Test{{ fg_class_name }}_LiveRoundTrip(t *testing.T) {
	testcontainers.SkipIfProviderIsNotHealthy(t)

	ctx := context.Background()
	container, err := servicebus.Run(ctx,
		"mcr.microsoft.com/azure-messaging/servicebus-emulator:1.1.2",
		servicebus.WithAcceptEULA(),
		servicebus.WithConfig(strings.NewReader(liveSbConfig)),
	)
	require.NoError(t, err)
	defer func() { _ = testcontainers.TerminateContainer(container) }()

	connStr, err := container.ConnectionString(ctx)
	require.NoError(t, err)

	producer, err := New{{ fg_class_name }}(connStr, "queue.1")
	require.NoError(t, err)
	defer producer.Close(ctx)

	var testData {{ fg_body_type }}
	sendSbLiveWithRetry(t, func() error {
		return producer.Send{{ fg_messagename }}(ctx, testData{% if fg_needs_source_param %}, "tenant123/device456"{% endif %}{% if "type" not in first_message.envelopemetadata %}, "{{ first_message_id }}"{% endif %})
	})

	client, err := azservicebus.NewClientFromConnectionString(connStr, nil)
	require.NoError(t, err)
	defer client.Close(ctx)
	receiver, err := client.NewReceiverForQueue("queue.1", nil)
	require.NoError(t, err)
	defer receiver.Close(ctx)

	rctx, cancel := context.WithTimeout(ctx, 30*time.Second)
	defer cancel()
	msgs, err := receiver.ReceiveMessages(rctx, 1, nil)
	require.NoError(t, err)
	require.Len(t, msgs, 1)
	require.NotNil(t, msgs[0].ContentType)
	assert.Equal(t, "application/cloudevents+json", *msgs[0].ContentType)

	var envelope map[string]any
	require.NoError(t, json.Unmarshal(msgs[0].Body, &envelope))
	assert.Equal(t, "{{ first_message.envelopemetadata.type.value if "type" in first_message.envelopemetadata and first_message.envelopemetadata.type.value else first_message_id }}", envelope["type"])
	_ = receiver.CompleteMessage(ctx, msgs[0], nil)
}

// sendSbLiveWithRetry retries sends because the emulator provisions the queue
// asynchronously and may reject the first few messages.
func sendSbLiveWithRetry(t *testing.T, fn func() error) {
	t.Helper()
	var err error
	for i := 0; i < 5; i++ {
		if err = fn(); err == nil {
			return
		}
		time.Sleep(2 * time.Second)
	}
	require.NoError(t, err)
}
