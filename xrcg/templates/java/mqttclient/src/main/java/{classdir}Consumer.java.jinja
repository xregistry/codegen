/**
 * MQTT 5.0 Consumer for {{ messagegroupid }} message group.
 * Processes messages from MQTT topics and dispatches them to registered handlers.
 */
public abstract class {{ consumer_class }} {
    private static final Logger logger = LogManager.getLogger({{ consumer_class }}.class);
    private static final Pattern URI_TEMPLATE_PATTERN = Pattern.compile("\\{([A-Za-z0-9_]+)\\}");

    protected final ObjectMapper objectMapper = new ObjectMapper();
    private final Map<String, String> topicMappings;
    private final Map<String, Pattern> topicPatterns;

    protected {{ consumer_class }}() {
        this(null);
    }

    protected {{ consumer_class }}(Map<String, String> topicMappings) {
        this.topicMappings = topicMappings != null ? new HashMap<>(topicMappings) : getDefaultTopicMappings();
        this.topicPatterns = buildTopicPatterns(this.topicMappings);
    }

    public static Map<String, String> getDefaultTopicMappings() {
        Map<String, String> mappings = new HashMap<>();
        {%- for messageid, message in messagegroup.messages.items() %}
        mappings.put("{{ messageid }}", "{{ get_default_topic(message, messageid) }}");
        {%- endfor %}
        return mappings;
    }

    public static List<String> getSubscriptionTopics(Map<String, String> topicMappings) {
        Map<String, String> mappings = topicMappings != null ? topicMappings : getDefaultTopicMappings();
        List<String> topics = new ArrayList<>();
        for (String topic : mappings.values()) {
            String wildcardTopic = URI_TEMPLATE_PATTERN.matcher(topic).replaceAll("+");
            if (!topics.contains(wildcardTopic)) {
                topics.add(wildcardTopic);
            }
        }
        return topics;
    }

    public static List<String> getSubscriptionTopics() {
        return getSubscriptionTopics(null);
    }

    public Map<String, String> getTopicMappings() {
        return new HashMap<>(topicMappings);
    }

    private static Map<String, Pattern> buildTopicPatterns(Map<String, String> topicMappings) {
        Map<String, Pattern> patterns = new HashMap<>();
        for (Map.Entry<String, String> entry : topicMappings.entrySet()) {
            String template = entry.getValue();
            Matcher matcher = URI_TEMPLATE_PATTERN.matcher(template);
            StringBuilder pattern = new StringBuilder("^");
            int last = 0;
            while (matcher.find()) {
                pattern.append(Pattern.quote(template.substring(last, matcher.start())));
                pattern.append("([^/]+)");
                last = matcher.end();
            }
            pattern.append(Pattern.quote(template.substring(last)));
            pattern.append("$");
            patterns.put(entry.getKey(), Pattern.compile(pattern.toString()));
        }
        return patterns;
    }

    protected Map<String, String> extractTopicParameters(String topic, String messageId) {
        Map<String, String> parameters = new HashMap<>();
        Pattern pattern = topicPatterns.get(messageId);
        String topicTemplate = topicMappings.get(messageId);
        if (pattern != null && topicTemplate != null) {
            Matcher matcher = pattern.matcher(topic);
            if (matcher.matches()) {
                Matcher templateMatcher = URI_TEMPLATE_PATTERN.matcher(topicTemplate);
                int groupIndex = 1;
                while (templateMatcher.find()) {
                    String groupName = templateMatcher.group(1);
                    if (groupIndex <= matcher.groupCount()) {
                        parameters.put(groupName, matcher.group(groupIndex));
                    }
                    groupIndex++;
                }
            }
        }
        return parameters;
    }

    /**
     * Process a message from MQTT.
     *
     * @param topic The topic the message was received on
     * @param message The MQTT 5.0 message, including properties and payload
     */
    public void processMessage(String topic, MqttMessage message) {
        try {
            dispatchMessage(topic, message);
        } catch (Exception ex) {
            logger.error("Error processing message from topic {}", topic, ex);
            handleError(ex, topic, message.getPayload());
        }
    }

    private void dispatchMessage(String topic, MqttMessage message) throws Exception {
        byte[] payload = message.getPayload();
        CloudEvent cloudEvent = null;
        if (isBinaryModeCloudEvent(message)) {
            cloudEvent = extractBinaryModeCloudEvent(message);
        } else if (isStructuredModeCloudEvent(payload)) {
            cloudEvent = parseStructuredModeCloudEvent(payload);
        }

        if (cloudEvent != null) {
            byte[] dataPayload = cloudEvent.getData() != null ? cloudEvent.getData().toBytes() : new byte[0];
            String eventType = cloudEvent.getType();
            switch (eventType) {
                {%- for messageid, message in messagegroup.messages.items() %}
                {%- set messagename = messageid | pascal | strip_namespace %}
                {%- set message_body_type = util.get_data_type(data_project_name, root, message) %}
                {%- set ce_type = messageid %}
                {%- if message.envelopemetadata and message.envelopemetadata.type and message.envelopemetadata.type.value %}
                {%- set ce_type = message.envelopemetadata.type.value %}
                {%- endif %}
                case "{{ ce_type }}": {
                    {%- if message_body_type == 'byte[]' %}
                    byte[] data = dataPayload;
                    {%- else %}
                    {{ message_body_type }} data = {{ message_body_type }}.fromData(dataPayload, cloudEvent.getDataContentType() != null ? cloudEvent.getDataContentType() : {{ cloudEvents.GetContentType(message) }});
                    {%- endif %}
                    Map<String, String> topicParams = extractTopicParameters(topic, "{{ messageid }}");
                    on{{ messagename }}(data, topic, topicParams);
                    return;
                }
                {%- endfor %}
                default:
                    logger.warn("Received CloudEvent type {} does not match any known message", eventType);
                    return;
            }
        }

        dispatchByTopic(topic, payload);
    }

    private void dispatchByTopic(String topic, byte[] payload) throws Exception {
        {%- for messageid, message in messagegroup.messages.items() %}
        {%- set messagename = messageid | pascal | strip_namespace %}
        {%- set message_body_type = util.get_data_type(data_project_name, root, message) %}

        if (topicPatterns.containsKey("{{ messageid }}") && topicPatterns.get("{{ messageid }}").matcher(topic).matches()) {
            try {
                {%- if message_body_type == 'byte[]' %}
                byte[] data = payload;
                {%- else %}
                {{ message_body_type }} data = {{ message_body_type }}.fromData(payload, "application/json");
                {%- endif %}
                Map<String, String> topicParams = extractTopicParameters(topic, "{{ messageid }}");
                on{{ messagename }}(data, topic, topicParams);
                return;
            } catch (Exception ex) {
                logger.trace("Message does not match {{ messagename }} schema", ex);
            }
        }
        {%- endfor %}

        logger.warn("Received message from topic {} does not match any known schema", topic);
    }

    private static boolean isBinaryModeCloudEvent(MqttMessage message) {
        MqttProperties props = message.getProperties();
        if (props == null) return false;
        List<UserProperty> userProps = props.getUserProperties();
        if (userProps == null || userProps.isEmpty()) return false;
        Set<String> keys = new HashSet<>();
        for (UserProperty up : userProps) keys.add(up.getKey().toLowerCase());
        return keys.containsAll(Arrays.asList("specversion", "type", "source", "id"));
    }

    private static CloudEvent extractBinaryModeCloudEvent(MqttMessage message) {
        MqttProperties props = message.getProperties();
        List<UserProperty> userProps = props.getUserProperties();
        CloudEventBuilder builder = CloudEventBuilder.v1();
        for (UserProperty up : userProps) {
            String key = up.getKey().toLowerCase();
            String val = up.getValue();
            switch (key) {
                case "id": builder.withId(val); break;
                case "type": builder.withType(val); break;
                case "source": builder.withSource(URI.create(val)); break;
                case "time": builder.withTime(OffsetDateTime.parse(val)); break;
                case "subject": builder.withSubject(val); break;
                case "dataschema": builder.withDataSchema(URI.create(val)); break;
                default:
                    if (!"specversion".equals(key)) builder.withExtension(key, val);
                    break;
            }
        }
        String contentType = props.getContentType();
        if (contentType != null) builder.withDataContentType(contentType);
        builder.withData(BytesCloudEventData.wrap(message.getPayload()));
        return builder.build();
    }

    private static boolean isStructuredModeCloudEvent(byte[] payload) {
        try {
            String json = new String(payload, StandardCharsets.UTF_8);
            Map<?, ?> map = new ObjectMapper().readValue(json, Map.class);
            return map.containsKey("specversion") && map.containsKey("type") && map.containsKey("source") && map.containsKey("id");
        } catch (Exception e) {
            return false;
        }
    }

    private static CloudEvent parseStructuredModeCloudEvent(byte[] payload) throws Exception {
        return EventFormatProvider.getInstance()
            .resolveFormat(JsonFormat.CONTENT_TYPE)
            .deserialize(payload);
    }

    {%- for messageid, message in messagegroup.messages.items() %}
    {%- set messagename = messageid | pascal | strip_namespace %}
    {%- set message_body_type = util.get_data_type(data_project_name, root, message) %}

    /**
     * Handler for {{ messagename }} messages.
     *
     * @param data The deserialized message data
     * @param topic The MQTT topic
     * @param topicParameters Map of URI template placeholder values extracted from the topic
     */
    protected abstract void on{{ messagename }}({{ message_body_type }} data, String topic, Map<String, String> topicParameters);
    {%- endfor %}

    protected void handleError(Exception ex, String topic, byte[] payload) {
        logger.error("Error processing message from topic {}", topic, ex);
    }
}
