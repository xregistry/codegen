    {%- if ph not in uri_template_vars %}{%- set _ = uri_template_vars.append(ph) %}{%- endif %}
    {%- endfor %}
    {%- endif %}
    {%- endfor %}
    {%- endif %}
    {%- for ph in default_topic | regex_search('\\{([A-Za-z0-9_]+)\\}') %}
    {%- if ph not in uri_template_vars %}{%- set _ = uri_template_vars.append(ph) %}{%- endif %}
    {%- endfor %}
    {%- set sub_topic = default_topic | regex_replace('\\{[A-Za-z0-9_]+\\}', '+') %}

    @Test
    @DisplayName("MQTT 5 binary CloudEvents round trip for {{ messagename }}")
    public void test{{ messagename }}BinaryCloudEventRoundTrip() throws Exception {
        CountDownLatch latch = new CountDownLatch(1);
        List<{{ message_body_type }}> receivedMessages = new ArrayList<>();
        List<String> receivedTopics = new ArrayList<>();
        List<Map<String, String>> receivedTopicParameters = new ArrayList<>();
        AtomicReference<MqttMessage> rawMessage = new AtomicReference<>();
        CountDownLatch rawLatch = new CountDownLatch(1);

        {{ group_package }}.{{ consumer_class }} messageConsumer = new {{ group_package }}.{{ consumer_class }}() {
            {%- for handler_messageid, handler_message in messagegroup.messages.items() %}
            {%- set handler_messagename = handler_messageid | pascal | strip_namespace %}
            {%- set handler_message_body_type = util.get_data_type(data_project_name, root, handler_message) %}
            @Override
            protected void on{{ handler_messagename }}({{ handler_message_body_type }} data, String topic, Map<String, String> topicParameters) {
                {%- if handler_messageid == messageid %}
                receivedMessages.add(data);
                receivedTopics.add(topic);
                receivedTopicParameters.add(topicParameters);
                latch.countDown();
                {%- else %}
                logger.info("Received {{ handler_messagename }} message while testing {{ messagename }}");
                {%- endif %}
            }
            {%- endfor %}
        };

        MqttEventClient consumer = MqttEventClient.createConsumerFor{{ pascal_group_name | strip_namespace }}(
            messageConsumer,
            brokerUrl,
            "test-consumer-" + UUID.randomUUID(),
            {{ group_package }}.{{ consumer_class }}.getSubscriptionTopics().toArray(new String[0])
        );

        MqttClient rawClient = createConnectedClient("raw-capture-" + UUID.randomUUID());
        rawClient.setCallback(new CapturingCallback(rawMessage, rawLatch));
        rawClient.subscribe("{{ sub_topic }}", 1);

        try {
            Thread.sleep(1000);
            MqttClient mqttClient = createConnectedClient("test-producer-" + UUID.randomUUID());
            {{ group_package }}.{{ producer_class }} producer = new {{ group_package }}.{{ producer_class }}(mqttClient);
            try {
                {%- if message_body_type == 'byte[]' %}
                byte[] testData = "test data".getBytes();
                {%- else %}
                {{ message_body_type }} testData = createTestData({{ message_body_type }}.class);
                {%- endif %}
                String expectedTopic = applyTopicTemplate("{{ default_topic }}"{% for ph in uri_template_vars %}, "{{ ph }}", "{{ ph }}Value"{% endfor %});

                producer.send{{ messagename }}(testData{% for ph in uri_template_vars %}, "{{ ph }}Value"{% endfor %});

                assertTrue(latch.await(20, TimeUnit.SECONDS), "{{ messagename }} should round-trip through Mosquitto");
                assertEquals(1, receivedMessages.size(), "Should receive exactly one {{ messagename }} message");
                assertEquals(expectedTopic, receivedTopics.get(0), "Topic template placeholders should be substituted");
                {%- for ph in topic_template_vars %}
                assertEquals("{{ ph }}Value", receivedTopicParameters.get(0).get("{{ ph }}"), "Topic parameter {{ ph }} should be extracted");
                {%- endfor %}

                assertTrue(rawLatch.await(20, TimeUnit.SECONDS), "Raw MQTT message should be captured");
                assertCloudEventBinaryProperties(rawMessage.get());
            } finally {
                producer.close();
            }
        } finally {
            rawClient.disconnect();
            rawClient.close();
            consumer.close();
        }
    }

    @Test
    @DisplayName("MQTT 5 QoS retain override and topic substitution for {{ messagename }}")
    public void test{{ messagename }}QosRetainOverrideAndTopicSubstitution() throws Exception {
        AtomicReference<MqttMessage> rawMessage = new AtomicReference<>();
        CountDownLatch rawLatch = new CountDownLatch(1);
        MqttClient rawClient = createConnectedClient("override-capture-" + UUID.randomUUID());
        rawClient.setCallback(new CapturingCallback(rawMessage, rawLatch));
        rawClient.subscribe("{{ sub_topic }}", 1);

        try {
            Thread.sleep(1000);
            MqttClient mqttClient = createConnectedClient("override-producer-" + UUID.randomUUID());
            {{ group_package }}.{{ producer_class }} producer = new {{ group_package }}.{{ producer_class }}(mqttClient);
            try {
                {%- if message_body_type == 'byte[]' %}
                byte[] testData = "test data".getBytes();
                {%- else %}
                {{ message_body_type }} testData = createTestData({{ message_body_type }}.class);
                {%- endif %}
                String expectedTopic = applyTopicTemplate("{{ default_topic }}"{% for ph in uri_template_vars %}, "{{ ph }}", "override{{ loop.index }}"{% endfor %});

                producer.send{{ messagename }}(testData{% for ph in uri_template_vars %}, "override{{ loop.index }}"{% endfor %}, null, 1, false);

                assertTrue(rawLatch.await(20, TimeUnit.SECONDS), "Override message should be captured");
                assertNotNull(rawMessage.get(), "Captured MQTT message should not be null");
                assertEquals(1, rawMessage.get().getQos(), "Per-call QoS override should be applied");
                assertFalse(rawMessage.get().isRetained(), "Per-call retain override should be applied");
            } finally {
                producer.close();
            }
        } finally {
            rawClient.disconnect();
            rawClient.close();
        }
    }
    {%- endfor %}
    {%- endfor %}

    private MqttClient createConnectedClient(String clientId) throws MqttException {
        MqttClient mqttClient = new MqttClient(brokerUrl, clientId);
        MqttConnectionOptions opts = new MqttConnectionOptions();
        opts.setCleanStart(true);
        opts.setAutomaticReconnect(false);
        mqttClient.connect(opts);
        return mqttClient;
    }

    private static void assertCloudEventBinaryProperties(MqttMessage message) {
        assertNotNull(message, "MQTT message should not be null");
        MqttProperties props = message.getProperties();
        assertNotNull(props, "MQTT 5 properties should be present");
        assertNotNull(props.getContentType(), "CloudEvents datacontenttype should map to MQTT contentType");
        Set<String> keys = new HashSet<>();
        List<UserProperty> userProperties = props.getUserProperties();
        assertNotNull(userProperties, "CloudEvents attributes should be MQTT user properties");
        for (UserProperty up : userProperties) {
            keys.add(up.getKey().toLowerCase());
        }
        assertTrue(keys.containsAll(Arrays.asList("specversion", "id", "type", "source")), "Required CloudEvents attributes should be user properties");
    }

    private static String applyTopicTemplate(String topicPattern, Object... kvPairs) {
        String result = topicPattern;
        for (int i = 0; i + 1 < kvPairs.length; i += 2) {
            result = result.replace("{" + kvPairs[i] + "}", String.valueOf(kvPairs[i + 1]));
        }
        return result;
    }

    private static <T> T createTestData(Class<T> clazz) throws Exception {
        T instance = clazz.getDeclaredConstructor().newInstance();
        populateAvroLike(instance);
        populateFields(instance);
        return instance;
    }

    private static void populateAvroLike(Object instance) {
        try {
            Method getSchema = instance.getClass().getMethod("getSchema");
            Object schema = getSchema.invoke(instance);
            Method getFields = schema.getClass().getMethod("getFields");
            List<?> fields = (List<?>) getFields.invoke(schema);
            Method put = instance.getClass().getMethod("put", int.class, Object.class);
            for (int i = 0; i < fields.size(); i++) {
                Object field = fields.get(i);
                Method nameMethod = field.getClass().getMethod("name");
                Method schemaMethod = field.getClass().getMethod("schema");
                String fieldName = String.valueOf(nameMethod.invoke(field));
                Object fieldSchema = schemaMethod.invoke(field);
                put.invoke(instance, i, sampleValue(fieldName, fieldSchema));
            }
        } catch (Exception ignored) {
            // Not an Avro-like generated type.
        }
    }

    private static void populateFields(Object instance) {
        for (Field field : instance.getClass().getDeclaredFields()) {
            if (java.lang.reflect.Modifier.isStatic(field.getModifiers())) {
                continue;
            }
            try {
                field.setAccessible(true);
                if (field.get(instance) == null || field.getType().isPrimitive()) {
                    field.set(instance, sampleValueForType(field.getName(), field.getType()));
                }
            } catch (Exception ignored) {
                // Best-effort population for generated data models.
            }
        }
    }

    private static Object sampleValue(String fieldName, Object schema) throws Exception {
        Object type = schema.getClass().getMethod("getType").invoke(schema);
        String typeName = String.valueOf(type);
        if ("UNION".equals(typeName)) {
            List<?> types = (List<?>) schema.getClass().getMethod("getTypes").invoke(schema);
            for (Object candidate : types) {
                Object candidateType = candidate.getClass().getMethod("getType").invoke(candidate);
                if (!"NULL".equals(String.valueOf(candidateType))) {
                    return sampleValue(fieldName, candidate);
                }
            }
            return null;
        }
        switch (typeName) {
            case "STRING": return fieldName + "Value";
            case "INT": return 42;
            case "LONG": return 42L;
            case "FLOAT": return 42.0f;
            case "DOUBLE": return 42.0d;
            case "BOOLEAN": return true;
            case "BYTES": return java.nio.ByteBuffer.wrap("bytes".getBytes());
            default: return null;
        }
    }

    private static Object sampleValueForType(String fieldName, Class<?> type) {
        if (type == String.class) return fieldName + "Value";
        if (type == int.class || type == Integer.class) return 42;
        if (type == long.class || type == Long.class) return 42L;
        if (type == float.class || type == Float.class) return 42.0f;
        if (type == double.class || type == Double.class) return 42.0d;
        if (type == boolean.class || type == Boolean.class) return true;
        if (type == byte[].class) return "bytes".getBytes();
        return null;
    }

    private static class CapturingCallback implements MqttCallback {
        private final AtomicReference<MqttMessage> rawMessage;
        private final CountDownLatch latch;

        CapturingCallback(AtomicReference<MqttMessage> rawMessage, CountDownLatch latch) {
            this.rawMessage = rawMessage;
            this.latch = latch;
        }

        @Override
        public void disconnected(MqttDisconnectResponse disconnectResponse) {
        }

        @Override
        public void mqttErrorOccurred(MqttException exception) {
            logger.error("MQTT capture error", exception);
        }

        @Override
        public void messageArrived(String topic, MqttMessage message) {
            rawMessage.set(message);
            latch.countDown();
        }

        @Override
        public void deliveryComplete(IMqttToken token) {
        }

        @Override
        public void connectComplete(boolean reconnect, String serverURI) {
        }

        @Override
        public void authPacketArrived(int reasonCode, MqttProperties properties) {
        }
    }
}
