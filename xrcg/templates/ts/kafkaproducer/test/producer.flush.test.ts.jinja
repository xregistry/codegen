import { describe, test, expect, jest } from '@jest/globals';
import { Producer, Message } from 'kafkajs';
{% for messagegroupid, messagegroup in messagegroups.items() -%}
{%- set pascal_group_name = messagegroupid | pascal %}
{%- set class_name = ( pascal_group_name | strip_namespace ) + "Producer" %}
import { {{ class_name }} } from '../src/producer';
{%- endfor %}

/**
 * Broker-free unit tests for the resilient `sendWithRetry()` logic.
 *
 * These use a fake KafkaJS `Producer` (no broker, Docker, or Testcontainers) and
 * verify that `sendWithRetry` retries transient failures and raises a terminal
 * error once the retry budget is exhausted. `backoffFactor` is 0 so retries are
 * zero-delay and the suite runs instantly; the retry COUNT and terminal
 * behaviour are the unit under test, not wall-clock backoff timing.
 */
{% for messagegroupid, messagegroup in messagegroups.items() -%}
{%- set pascal_group_name = messagegroupid | pascal %}
{%- set class_name = ( pascal_group_name | strip_namespace ) + "Producer" %}
describe('{{ pascal_group_name }} Producer sendWithRetry resilience', () => {
    const sampleRecord = { topic: 'test-topic', messages: [{ value: Buffer.from('payload') }] as Message[] };

    test('resolves without retrying when the first send succeeds', async () => {
        const send = jest.fn<() => Promise<void>>().mockResolvedValue(undefined);
        const fakeProducer = { send } as unknown as Producer;
        const producer = new {{ class_name }}(fakeProducer);

        await producer.sendWithRetry(sampleRecord, 3, 0);

        expect(send).toHaveBeenCalledTimes(1);
    });

    test('retries after a transient failure and then succeeds', async () => {
        const send = jest.fn<() => Promise<void>>()
            .mockRejectedValueOnce(new Error('transient broker error'))
            .mockResolvedValue(undefined);
        const fakeProducer = { send } as unknown as Producer;
        const producer = new {{ class_name }}(fakeProducer);

        await producer.sendWithRetry(sampleRecord, 3, 0);

        expect(send).toHaveBeenCalledTimes(2);
    });

    test('rejects after exhausting all retries', async () => {
        const send = jest.fn<() => Promise<void>>().mockRejectedValue(new Error('persistent broker error'));
        const fakeProducer = { send } as unknown as Producer;
        const producer = new {{ class_name }}(fakeProducer);

        await expect(producer.sendWithRetry(sampleRecord, 2, 0)).rejects.toThrow('Kafka send failed after 2 attempts');

        expect(send).toHaveBeenCalledTimes(2);
    });
});
{% endfor %}
