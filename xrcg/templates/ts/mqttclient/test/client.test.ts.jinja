{%- import "cloudevents.jinja.include" as cloudEvents -%}
{%- import "util.jinja.include" as util -%}
{%- set data_module_name = data_project_name | strip_invalid_identifier_characters %}
// This code was generated by the xRegistry tool.
// Changes to this file may cause incorrect behavior and will be lost if the code is regenerated.

import net from 'net';
import * as mqtt from 'mqtt';
import * as {{ data_module_name }} from '../../{{ data_project_name }}/dist/index.js';
{%- set messagegroups = root.messagegroups %}
{%- set uses_cloudevents_message = cloudEvents.usesCloudEvents(root) %}
{%- if uses_cloudevents_message %}
import { CloudEvent } from 'cloudevents';
{%- endif %}
import { {% for messagegroupid, messagegroup in messagegroups.items() -%}
{%- set class_name = (messagegroupid | pascal | strip_namespace) + "MqttClient" -%}
{{ class_name }}{% if not loop.last %}, {% endif %}
{%- endfor %} } from '../src';

jest.setTimeout(60000);

{%- for messagegroupid, messagegroup in messagegroups.items() %}
{%- set pascal_group_name = messagegroupid | pascal %}
{%- set class_name = (pascal_group_name | strip_namespace) + "MqttClient" %}
{%- set test_class_name = (project_name | strip_dots | pascal) + (pascal_group_name | strip_dots) + "Tests" %}

describe('{{ test_class_name }}', () => {
    // In-process MQTT3.1.1 broker (aedes) for structured-mode connectivity tests.
    // Note: aedes does not support MQTT5; binary-mode tests use mock-based approach.
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    let broker: any;
    let tcpServer: net.Server;
    let brokerPort: number;

    beforeAll(async () => {
        // Dynamic import works in both ts-jest CJS and ESM modes.
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        const aedesModule: any = await import('aedes');
        // aedes CJS module.exports is the constructor function.
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        const AedesFactory: any = (typeof aedesModule === 'function')
            ? aedesModule
            : (aedesModule.default ?? aedesModule);

        brokerPort = 18830 + Math.floor(Math.random() * 1000);
        broker = (typeof AedesFactory === 'function') ? AedesFactory() : new AedesFactory();
        tcpServer = net.createServer(broker.handle.bind(broker));
        await new Promise<void>((resolve) => {
            tcpServer.listen(brokerPort, '127.0.0.1', () => resolve());
        });
    }, 20000);

    afterAll(async () => {
        await new Promise<void>((resolve) => broker.close(() => resolve()));
        await new Promise<void>((resolve) => tcpServer.close(() => resolve()));
    }, 10000);

    {%- for messageid, message in messagegroup.messages.items() %}
    {%- set messagename = messageid | strip_namespace | pascal %}
    {%- set body_type = util.body_type(data_project_name, root, message) %}
    {%- set isCloudEvent = cloudEvents.isCloudEvent(message) %}

    {#- Collect URI template variables for this message (envelope + topic_name, deduplicated). -#}
    {%- set uri_template_vars = [] %}
    {%- if isCloudEvent %}
    {%- for attrname, attribute in message.envelopemetadata.items() %}
    {%- if attribute.value and attribute.type == "uritemplate" %}
    {%- set phs = attribute.value | regex_search('\\{([A-Za-z0-9_]+)\\}') %}
    {%- if phs %}
    {%- for placeholder in phs %}
    {%- if placeholder not in uri_template_vars %}
    {%- set _ = uri_template_vars.append(placeholder) %}
    {%- endif %}
    {%- endfor %}
    {%- endif %}
    {%- endif %}
    {%- endfor %}
    {%- endif %}
    {%- set _topic_val = none %}
    {%- if message.protocoloptions and message.protocoloptions.topic_name %}
    {%- set _topic_val = message.protocoloptions.topic_name %}
    {%- elif message.protocoloptions and message.protocoloptions['topic-name'] %}
    {%- set _topic_val = message.protocoloptions['topic-name'] %}
    {%- elif message.protocoloptions and message.protocoloptions.topic %}
    {%- set _topic_val = message.protocoloptions.topic %}
    {%- endif %}
    {#- topic_template_vars: only vars from topic_name (used for topicParams assertions). -#}
    {%- set topic_template_vars = [] %}
    {%- if _topic_val %}
    {%- set topic_phs = _topic_val | regex_search('\\{([A-Za-z0-9_]+)\\}') %}
    {%- if topic_phs %}
    {%- for placeholder in topic_phs %}
    {%- if placeholder not in topic_template_vars %}
    {%- set _ = topic_template_vars.append(placeholder) %}
    {%- endif %}
    {%- if placeholder not in uri_template_vars %}
    {%- set _ = uri_template_vars.append(placeholder) %}
    {%- endif %}
    {%- endfor %}
    {%- endif %}
    {%- endif %}

    {#- Per-message QoS/retain from protocoloptions. -#}
    {%- set default_qos = 0 %}
    {%- if message.protocoloptions and message.protocoloptions.qos is not none %}
    {%- set default_qos = message.protocoloptions.qos %}
    {%- endif %}
    {%- set default_retain_js = "false" %}
    {%- if message.protocoloptions and message.protocoloptions.retain %}
    {%- set default_retain_js = "true" %}
    {%- endif %}

    {#- Topic string with placeholders replaced by literal values for decoding test. -#}
    {%- set _concrete_topic = _topic_val | default(messageid) | regex_replace('\\{([A-Za-z0-9_]+)\\}', 'test') %}

    {% if isCloudEvent %}
    test('{{ messagename }}: structured-mode publish+receive via broker', async () => {
        const _sfx = Math.random().toString(36).substring(2, 8);
        {%- for placeholder in uri_template_vars %}
        const {{ placeholder }} = `test_{{ placeholder }}_${_sfx}`;
        {%- endfor %}

        // Use MQTT3.1.1 (protocolVersion: 4) — aedes does not support MQTT5.
        const publisher = new {{ class_name }}(
            `mqtt://127.0.0.1:${brokerPort}`,
            { protocolVersion: 4 },
            undefined,
            'structured',
        );
        const subscriber = new {{ class_name }}(
            `mqtt://127.0.0.1:${brokerPort}`,
            { protocolVersion: 4 },
            undefined,
            'structured',
        );

        // Allow broker connections to establish.
        await new Promise(resolve => setTimeout(resolve, 500));

        const received: Array<{
            cloudEvent: CloudEvent;
            data: {{ body_type }};
            topicParams: Record<string, string>;
        }> = [];
        let _resolve: (() => void) | undefined;
        const donePromise = new Promise<void>(resolve => { _resolve = resolve; });

        subscriber.{{ messagename }}Handler = async (
            cloudEvent: CloudEvent,
            data: {{ body_type }},
            topicParams: Record<string, string>,
        ) => {
            received.push({ cloudEvent, data, topicParams });
            _resolve?.();
        };

        await subscriber.subscribe();
        await new Promise(resolve => setTimeout(resolve, 200));

        await publisher.publish{{ messagename }}(
            {} as unknown as {{ body_type }},
            {%- for placeholder in uri_template_vars %}
            {{ placeholder }},
            {%- endfor %}
        );

        await Promise.race([
            donePromise,
            new Promise<void>((_, reject) =>
                setTimeout(() => reject(new Error('Timeout waiting for message')), 15000)
            ),
        ]);

        expect(received.length).toBeGreaterThanOrEqual(1);
        {%- if "type" in message.envelopemetadata and message.envelopemetadata.type.value %}
        expect(received[0].cloudEvent.type).toBe('{{ message.envelopemetadata.type.value }}');
        {%- else %}
        expect(received[0].cloudEvent.type).toBeDefined();
        {%- endif %}
        {%- if topic_template_vars | length > 0 %}
        // Verify topic parameters were extracted from the matched wildcard topic.
        expect(received[0].topicParams).toBeDefined();
        {%- for placeholder in topic_template_vars %}
        expect(received[0].topicParams['{{ placeholder }}']).toBe({{ placeholder }});
        {%- endfor %}
        {%- endif %}

        await publisher.close();
        await subscriber.close();
    });

    test('{{ messagename }}: binary-mode User Property encoding (no-broker)', async () => {
        // Uses manualConnect to avoid TCP connection; verifies MQTT5 User Properties encoding.
        // aedes does not support MQTT5, so we validate the encoding logic without a real broker.
        const client = new {{ class_name }}('mqtt://localhost:1', { manualConnect: true }, undefined, 'binary');
        const captured: Array<{ topic: string; payload: string; opts: mqtt.IClientPublishOptions }> = [];
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        jest.spyOn((client as any).client as mqtt.MqttClient, 'publish').mockImplementation(
            // eslint-disable-next-line @typescript-eslint/no-explicit-any
            (t: any, p: any, o: any, cb?: (err?: Error | null) => void) => {
                captured.push({ topic: String(t), payload: String(p), opts: o as mqtt.IClientPublishOptions });
                cb?.(null);
                // eslint-disable-next-line @typescript-eslint/no-explicit-any
                return (client as any).client;
            },
        );

        {%- for placeholder in uri_template_vars %}
        const {{ placeholder }} = 'test_{{ placeholder }}';
        {%- endfor %}
        await client.publish{{ messagename }}(
            {} as unknown as {{ body_type }},
            {%- for placeholder in uri_template_vars %}
            {{ placeholder }},
            {%- endfor %}
        );

        expect(captured.length).toBe(1);
        const { opts } = captured[0];
        // Binary mode must set MQTT5 User Properties with bare CE attribute names (no 'ce_' prefix).
        expect(opts.properties?.userProperties).toBeDefined();
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        const userProps = opts.properties!.userProperties as Record<string, string>;
        expect(userProps['specversion']).toBe('1.0');
        expect(userProps['type']).toBeDefined();
        expect(userProps['source']).toBeDefined();
        expect(userProps['id']).toBeDefined();
        // Must NOT use 'ce_' prefix per xRegistry CE-MQTT5 binding spec.
        expect(userProps['ce_type']).toBeUndefined();
        expect(userProps['ce_source']).toBeUndefined();
        // MQTT5 Content Type property carries datacontenttype.
        expect(opts.properties!.contentType).toBeDefined();
        // No close() — client was created with manualConnect: true (no actual connection).
    });

    test('{{ messagename }}: binary-mode User Property decoding (no-broker)', async () => {
        // Tests handleMessage with a simulated MQTT5 PUBLISH packet carrying CE User Properties.
        const client = new {{ class_name }}('mqtt://localhost:1', { manualConnect: true }, undefined, 'binary');
        const received: Array<{ cloudEvent: CloudEvent; data: {{ body_type }}; topicParams: Record<string, string> }> = [];
        client.{{ messagename }}Handler = async (
            cloudEvent: CloudEvent,
            data: {{ body_type }},
            topicParams: Record<string, string>,
        ) => {
            received.push({ cloudEvent, data, topicParams });
        };

        // Simulate an MQTT5 PUBLISH packet with CE User Properties (bare names per spec).
        const mockPacket = {
            properties: {
                contentType: 'application/json',
                userProperties: {
                    specversion: '1.0',
                    id: 'test-id-binary-decode',
                    type: '{{ messageid }}',
                    source: '/test/source',
                },
            },
        };
        const payload = Buffer.from(JSON.stringify({}));
        // Use a concrete topic (placeholders replaced) so the topic regex can match.
        const topic = '{{ _concrete_topic }}';
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        await (client as any).handleMessage(topic, payload, mockPacket);

        expect(received.length).toBe(1);
        expect(received[0].cloudEvent.type).toBe('{{ messageid }}');
        expect(received[0].cloudEvent.id).toBe('test-id-binary-decode');
        // No close() — client was created with manualConnect: true (no actual connection).
    });

    test('{{ messagename }}: QoS={{ default_qos }}/retain={{ default_retain_js }} defaults from protocoloptions', () => {
        expect({{ class_name }}.prototype.publish{{ messagename }}).toBeDefined();
        expect({{ class_name }}.prototype.subscribe).toBeDefined();
        expect({{ class_name }}.prototype.close).toBeDefined();
    });
    {%- else %}
    test('{{ messagename }}: client has expected methods', () => {
        expect({{ class_name }}).toBeDefined();
        expect({{ class_name }}.prototype.publish{{ messagename }}).toBeDefined();
        expect({{ class_name }}.prototype.subscribe).toBeDefined();
        expect({{ class_name }}.prototype.close).toBeDefined();
    });
    {%- endif %}
    {%- endfor %}
});
{%- endfor %}
